             release-assets/pacman-pkg/*
             release-assets/appimage/*
             release-assets/flatpak/*
+
+  # ────────────────────────────────────────────────────────────────── #
+  #  Publish version + links summary                                  #
+  #  Always runs last, regardless of which build jobs succeeded, so    #
+  #  the workflow run page always shows the package name and version  #
+  #  you picked, linked directly to where it actually landed.         #
+  # ────────────────────────────────────────────────────────────────── #
+  publish-summary:
+    name: Publish version summary
+    runs-on: ubuntu-22.04
+    needs: [meta, publish-pypi, create-release]
+    if: always()
+    steps:
+      - name: Write summary
+        run: |
+          PACKAGE="${{ needs.meta.outputs.package }}"
+          VERSION="${{ needs.meta.outputs.version }}"
+          TAG="${{ needs.meta.outputs.tag }}"
+          REPO="${{ github.server_url }}/${{ github.repository }}"
+
+          RELEASE_STATUS="${{ needs['create-release'].result }}"
+          PYPI_STATUS="${{ needs['publish-pypi'].result }}"
+
+          {
+            echo "## 📦 ${PACKAGE} ${VERSION} — published"
+            echo ""
+            echo "| Target | Status | Link |"
+            echo "|---|---|---|"
+            if [ "$RELEASE_STATUS" = "success" ]; then
+              echo "| GitHub Release | ✅ | [${TAG}](${REPO}/releases/tag/${TAG}) |"
+            else
+              echo "| GitHub Release | ⚠️ ${RELEASE_STATUS} | [${TAG}](${REPO}/releases/tag/${TAG}) |"
+            fi
+            if [ "$PYPI_STATUS" = "success" ]; then
+              echo "| PyPI | ✅ | [${PACKAGE} ${VERSION}](https://pypi.org/project/${PACKAGE}/${VERSION}/) |"
+            else
+              echo "| PyPI | ⚠️ ${PYPI_STATUS} | [${PACKAGE} ${VERSION}](https://pypi.org/project/${PACKAGE}/${VERSION}/) |"
+            fi
+            echo "| Workflow run | — | [this run](${REPO}/actions/runs/${{ github.run_id }}) |"
+            echo ""
+            echo "_Resolved from: $([ "${{ github.event_name }}" = "workflow_dispatch" ] && echo "manual input \`${VERSION}\`" || echo "pushed tag \`${GITHUB_REF_NAME}\`")_"
+          } >> "$GITHUB_STEP_SUMMARY"
diff --git a/packaging/PKGBUILD b/packaging/PKGBUILD
index 7286652..ba6ab03 100644
--- a/packaging/PKGBUILD
+++ b/packaging/PKGBUILD
@@ -48,7 +48,19 @@ prepare() {
     cd "${pkgname}-${pkgver}"
     # Install Python dependencies into a venv for packaging
     python -m venv --system-site-packages .venv
-    .venv/bin/pip install --no-build-isolation \
+    # NOTE: do NOT pass --no-build-isolation here. Several transitive deps
+    # (e.g. evdev, pulled in by pynput) ship as sdists that need to compile
+    # a C extension and declare their own build-system requirements
+    # (setuptools, wheel, sometimes cython) in pyproject.toml. Disabling
+    # build isolation forces pip to use whatever's already importable in
+    # this venv instead of fetching those declared build deps — which is
+    # exactly what caused CI failures like:
+    #   pip._vendor.pyproject_hooks._impl.BackendUnavailable:
+    #   Cannot import 'setuptools.build_meta'
+    # Build isolation is cheap (it's just build-time tooling, not runtime
+    # dependencies) and lets each sdist bring its own correct build deps.
+    .venv/bin/pip install --upgrade pip setuptools wheel
+    .venv/bin/pip install \
         faster-whisper \
         openai \
         chromadb \
